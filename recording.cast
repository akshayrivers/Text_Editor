[0.165, "o", "\u001b[?25l\u001b[1;1H\u001b[2K\u001b[38;5;12m[![Build](https://github.com/akshayrivers/Text_Editorr/actions/workflows/rust.yml/badge.svg)\u001b[0m\u001b[38;5;13m](https://github.com/akshayrivers/Text_\u001b[0mEditorr/actions/workflows/rust.yml)\u001b[0m\u001b[2;1H\u001b[2K\u001b[3;1H\u001b[2K\u001b[38;5;14m# Yonro's Terminal based text editor\u001b[0m\u001b[4;1H\u001b[2K\u001b[5;1H\u001b[2KInitially it had been a faithful implementation of the text editor built in the \u001b[0m\u001b[38;5;12m[Hecto tutorial](https://www.flenker.blog/hecto/)\u001b[0m. But I have enhanced and changed it into something which I can use as a wr\u001b[0m\u001b[6;1H\u001b[2KFor detailed notes please refer to /notes.md\u001b[0m\u001b[7;1H\u001b[2K\u001b[8;1H\u001b[2K\u001b[38;5;14m## Demo\u001b[0m\u001b[9;1H\u001b[2K\u001b[10;1H\u001b[2K!\u001b[0m\u001b[38;5;12m[demo](./demo1.gif)\u001b[0m\u001b[11;1H\u001b[2K\u001b[12;1H\u001b[2K\u001b[38;5;14m## Overview & Design Philosophy\u001b[0m\u001b[13;1H\u001b[2K\u001b[14;1H\u001b[2KInstead of jumping directly into features, the editor was built in layers:\u001b[0m\u001b[15;1H\u001b[2K\u001b[16;1H\u001b[2K\u001b[38;5;10m- Terminal control\u001b[0m\u001b[17;1H\u001b[2K\u001b[38;5;10m- Rendering\u001b[0m\u001b[18;1H\u001b[2K\u001b[38;5;10m- Editing\u001b[0m\u001b[19;1H\u001b[2K\u001b[38;5;10m- Search\u001b[0m\u001b[20;1H\u001b[2K"]
[0.000, "o", "\u001b[38;5;10m- Highlighting\u001b[0m\u001b[21;1H\u001b[2K\u001b[38;5;10m- Extensibility\u001b[0m\u001b[22;1H\u001b[2Khello there !!!!\u001b[0m\u001b[23;1H\u001b[2KEach phase builds on the previous one, gradually evolving the editor from a\u001b[0m\u001b[24;1H\u001b[2Ksimple terminal viewer into a fully functional text editor.\u001b[0m\u001b[25;1H\u001b[2K\u001b[26;1H\u001b[2KSome guiding principles during development:\u001b[0m\u001b[27;1H\u001b[2K\u001b[28;1H\u001b[2K\u001b[38;5;10m- Keep core editor synchronous and stable\u001b[0m\u001b[29;1H\u001b[2K\u001b[38;5;10m- Prefer simple data structures first\u001b[0m\u001b[30;1H\u001b[2K\u001b[38;5;10m- Unicode correctness over premature optimization\u001b[0m\u001b[31;1H\u001b[2K\u001b[38;5;10m- Stateless rendering where possible\u001b[0m\u001b[32;1H\u001b[2K\u001b[38;5;10m- Design for extensibility (plugins later)\u001b[0m\u001b[33;1H\u001b[2K\u001b[34;1H\u001b[2KThis allowed the editor to evolve organically while keeping complexity manageable.\u001b[0m\u001b[35;1H\u001b[2K\u001b[36;1H\u001b[2K\u001b[38;5;14m## Quick Start\u001b[0m\u001b[37;1H\u001b[2K\u001b[38;1H\u001b[2K\u001b[38;5;14m### Requirements\u001b[0m\u001b[39;1H\u001b[2K\u001b[40;1H\u001b[2K\u001b[38;5;10m- Rust (stable)\u001b[0m\u001b[41;1H\u001b[2K\u001b[38;5;10m- Terminal with UTF-8 support\u001b[0m\u001b[42;1H\u001b[2K\u001b[43;1H\u001b[2K\u001b[38;5;14m### "]
